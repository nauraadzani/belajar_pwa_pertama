{
  "id": "/belajar_pwa_pertama/",
  "name": "Aplikasi WaroengPintar",
  "short_name": "WaroengPintar",
  "description": "Aplikasi belajar Progressive Web App sederhana untuk memahami konsep dasar PWA seperti service worker dan manifest.",
  "categories": ["finance", "productivity", "tools"],
  "start_url": "/belajar_pwa_pertama/index.html",
  "scope": "/belajar_pwa_pertama/",
  "scope_extensions": [
    {
      "origin": "https://*.nauraadzani.github.io"
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "text/csv": [".csv"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "auto"
  },
  "protocol_handlers": [
    {
      "protocol": "web+waroeng",
      "url": "./index.html?action=%s"
    }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "widgets": [
    {
      "name": "WaroengPintar Widget",
      "description": "Widget untuk WaroengPintar",
      "tag": "waroeng-widget",
      "ms_ac_template": "widget.json",
      "data": "widget-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "icons/screenshot1.png",
          "sizes": "1442x3090",
          "label": "Widget Screenshot"
        }
      ],
      "icons": [
        {
          "src": "icons/launchericon-512x512.png",
          "sizes": "512x512"
        }
      ]
    }
  ],
  "display": "standalone",
  "display_override": ["tabbed", "standalone", "minimal-ui"],
  "background_color": "#601515",
  "theme_color": "#601515",
  "orientation": "portrait",
  "lang": "id",
  "dir": "ltr",
  "icons": [
    {
      "src": "icons/launchericon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/launchericon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "icons/screenshot1.png",
      "sizes": "1442x3090",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "icons/screenshot2.png",
      "sizes": "1442x3090",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "icons/screenshot-wide.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide"
    }
  ],
  "shortcuts": [
    {
      "name": "Buka Beranda",
      "short_name": "Home",
      "url": "./index.html",
      "icons": [{ "src": "./icons/launchericon-512x512.png", "sizes": "512x512" }]
    }
  ],
  "related_applications": [
    {
      "platform": "play",
